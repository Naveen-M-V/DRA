# Server runtime
NODE_ENV=production
PORT=3000

# Sell.do
SELL_DO_API_KEY=replace_with_your_sell_do_api_key

# Gmail SMTP for email verification (get app password from Gmail settings)
GMAIL_EMAIL=your_gmail_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Admin password for stats page
ADMIN_PASSWORD=your_secure_admin_password
